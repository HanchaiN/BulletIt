extends layout

block content
  .card.error-card
    h2 ⚠ Error
    p#error= message
    
    if error && error.status
      p.error-status
        strong Status Code:
        code= ' ' + error.status

    if error && error.stack && process.env.NODE_ENV === 'development'
      details.error-stack-wrapper
        summary.error-stack-toggle View Stack Trace
        pre.error-stack= error.stack

    div(style='margin-top: var(--spacing-xl);')
      a.btn.btn-primary(href='/') ← Back to Home
