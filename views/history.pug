extends layout

block content
  h1 Bulletin History

  .card
    h3 Change Timeline
    ul.history-list
      if list.length === 0
        li.empty-state
          div.empty-state-icon 📜
          div.empty-state-text No history yet
      else
        each val in (list || [])
          li.history-item
            if val.image_url
              .history-media-container
                span(style='font-size: 0.65rem; color: var(--primary); font-weight: 800; text-transform: uppercase;') Media Changed:
                if val.media_ext === 'pdf'
                  embed.list-thumbnail(src=val.image_url + '#toolbar=0&navpanes=0&scrollbar=0&view=Fit', type='application/pdf', loading='lazy', style='pointer-events: none; border: none; overflow: hidden;')
                else if val.media_ext === 'mp4' || val.media_ext === 'mov'
                  video.list-thumbnail(src=val.image_url, muted, loading='lazy')
                else
                  img.list-thumbnail(src=val.image_url, alt=(val.title || 'History media'), loading='lazy')
            div
              if val.content && String(val.content).trim() !== ''
                div.mb-2
                  strong Content:
                  br
                  span= val.content
              if val.is_active !== null
                div
                  strong Status:
                  br
                  span.badge(class=val.is_active ? 'badge-success' : 'badge-gray')
                    = val.is_active ? '✓ Active' : 'Archived'
