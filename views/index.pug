extends layout

block content
  div.layout-row-between.mb-lg
    h1#egg-67-trigger My Bulletins
    a.btn.btn-primary(href='/bullet/new') + Create New

  ul.filter-tabs
    li: a(href='/?q=all', class=filter === 'all' ? 'active' : null, role='button') All
    li: a(href='/?q=active', class=filter === 'active' ? 'active' : null, role='button') Active
    li: a(href='/?q=archive', class=filter === 'archive' ? 'active' : null, role='button') Archive

  div#response

  .card
    h3 Bulletins
    .masonry-grid
      ul#bullets
        if list.length === 0
          li.empty-state
            div.empty-state-icon 📝
            div.empty-state-text No bulletins yet. Create your first one above!
        else
          each val in (list || [])
            li.masonry-item.card(data-bulletin-id=val.id)
              a(href=`/bullet/${val.id}`)
                if val.image_url
                  if val.media_ext === 'pdf'
                    embed.bullet-thumbnail(src=val.image_url + '#toolbar=0&navpanes=0&scrollbar=0&view=Fit', type='application/pdf', loading='lazy', style='pointer-events: none; overflow: hidden; border: none;')
                  else if val.media_ext === 'mp4' || val.media_ext === 'mov'
                    video.bullet-thumbnail(src=val.image_url, muted, loop, loading='lazy', onmouseover="this.play()", onmouseout="this.pause()")
                  else
                    img.bullet-thumbnail(src=val.image_url, alt=(val.title || 'Bulletin media'), loading='lazy')
                div.bulletin-content.card-padding
                  h3(style="margin-bottom: 0.5rem; font-size: 1.25rem;")= val.title || 'Untitled'
                  div.bulletin-text-truncate= val.content
                  div.bulletin-meta
                    span.badge(class=val.is_active ? 'badge-success' : 'badge-gray')
                      = val.is_active ? '✓ Active' : 'Archived'
              .form-actions
                form.archive-form(method='POST', action=`/${val.id}`, enctype='multipart/form-data')
                  input(type='hidden', name='active', value=val.is_active ? 'false' : 'true')
                  button.btn.btn-small(type='submit', class=val.is_active ? 'btn-danger' : 'btn-primary')= val.is_active ? 'Archive' : 'Revive'
                a.btn.btn-secondary(href='/' + val.id + '/history') History

