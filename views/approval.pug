extends layout

block content
  h1 Review Patches

  div#response

  .masonry-grid
    ul#bullets
      if list.length === 0
        li.empty-state
          div.empty-state-icon 🥀
          div.empty-state-text No patches to review
      else
        each bullet in (list || [])
          //- BULLETPROOF FALLBACK: Ensure patches is an array before looping
          - let safePatches = [];
          - if (typeof bullet.patches === 'string') { try { safePatches = JSON.parse(bullet.patches); } catch(e) {} } else { safePatches = bullet.patches || []; }

          each patch in safePatches
            li.masonry-item.card(style="cursor: pointer; transition: transform 0.2s;")
              a(href=`/patch/${patch.id}`, style="text-decoration: none; color: inherit; display: block;")
                - const proposedMediaExt = patch.media_ext || (patch.image_url ? patch.image_url.split('.').pop().toLowerCase() : '');
                - const displayImage = patch.image_url || bullet.image_url;
                - const displayExt = patch.image_url ? proposedMediaExt : (bullet.media_ext || (bullet.image_url ? bullet.image_url.split('.').pop().toLowerCase() : ''));

                if displayImage
                  div.card-relative
                    if patch.image_url
                      span.badge.media-badge New Media
                    if displayExt === 'pdf'
                      embed.bullet-thumbnail(src=displayImage + '#toolbar=0&navpanes=0&scrollbar=0&view=Fit', type='application/pdf', loading='lazy', style='pointer-events: none;')
                    else if displayExt === 'mp4' || displayExt === 'mov'
                      video.bullet-thumbnail(src=displayImage, muted, loop, loading='lazy', onmouseover="this.play()", onmouseout="this.pause()")
                    else
                      img.bullet-thumbnail(src=displayImage, alt=(patch.title || bullet.title || 'Patch media'), loading='lazy')

                div(style="padding: 1.5rem; text-align: left;")
                  div(style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;")
                    span.badge(style="background: var(--warning); color: white;") Patch ##{patch.id}
                    if patch.image_url
                      span.badge(style="background: var(--primary); color: white; font-size: 0.7rem;") MEDIA UPDATE
                  h3(style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.5rem; color: var(--text-main);")= patch.title || bullet.title || 'Untitled'
                  div.bulletin-text-truncate(style="color: var(--text-muted);")= patch.content || bullet.content || 'Status update only'
                  div(style="margin-top: 1.25rem; color: var(--primary); font-weight: 700; font-size: 0.85rem;") CLICK TO REVIEW
