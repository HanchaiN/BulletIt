extends ../layout

block content
  .page-panel
    .layout-row-between.mb-lg
      h1 Create New Bulletin
      a.btn.btn-ghost(href='/')
        span ←
        span Back

    .form-wrapper
      .card
        form#bulletin-form.form-vertical(method='POST', action='/bullet', enctype='multipart/form-data')
          
          //- The Upload Zone
          .upload-zone#drop-zone
            label
              span.upload-icon
                svg(xmlns='http://www.w3.org/2000/svg', viewBox='0 0 24 24', fill='none', stroke='currentColor', stroke-width='1.8', stroke-linecap='round', stroke-linejoin='round', width='24', height='24')
                  path(d='M12 16v-6')
                  path(d='M8 12l4-4 4 4')
                  path(d='M20 16v2a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-2')
                  line(x1='12', y1='18', x2='12', y2='22')
              span Upload a photo, video, or PDF
              input#image-upload(type='file', name='image', accept='.jpg, .jpeg, .png, .pdf, .mp4, .mov')
          
          //- The Live Preview Container
          .preview-container.hidden#preview-box
            button.btn.remove-preview-btn#remove-btn(type="button") ✕ Remove

          //- Topic Content
          label.form-label(for='title') Topic
          input.main-input(type='text', name='title', id='title', placeholder='Topic', maxlength='255', required, style='margin-bottom: 1rem;')

          //- Text Content
          label.form-label(for='content') Description
          textarea.main-textarea(name='content', id='content', placeholder='Description', maxlength='5000', rows='6', required, class='mb-lg')
          
          label.form-label(for='active_at') Active at:
          input(id='active_at', name='active_at', type='datetime-local')

          label.form-label(for='expire_at') Expires at:
          input(id='expire_at', name='expire_at', type='datetime-local')

          .form-actions.full-width
            button.btn.btn-primary#submit-btn(type='submit', style='width: 100%; padding: 0.75rem; font-size: 1rem;') Submit Bulletin

  //- Client-Side Logic for Live Preview
  script.
    let currentObjectUrl = null;

    function updatePreview(file, previewBox, dropZone) {
      if (!file) return;
      
      // Check file size (50 MB limit)
      if (file.size > 50 * 1024 * 1024) {
        alert('File too large. Maximum file size is 50 MB.');
        return;
      }
      
      // Revoke the old ObjectURL to prevent memory leaks
      if (currentObjectUrl) {
        URL.revokeObjectURL(currentObjectUrl);
      }
      
      const url = URL.createObjectURL(file);
      currentObjectUrl = url;
      
      // Remove old preview elements (keeping the remove button)
      Array.from(previewBox.children).forEach(child => {
        if (child.id !== 'remove-btn') child.remove();
      });

      const fileType = file.type || '';
      const fileName = (file.name || '').toLowerCase();
      
      let previewEl;
      if (fileType.startsWith('video/') || fileName.endsWith('.mp4') || fileName.endsWith('.mov')) {
        previewEl = document.createElement('video');
        previewEl.src = url;
        previewEl.controls = true;
        previewEl.className = 'preview-thumbnail';
        previewEl.loading = 'lazy';
      } else if (fileType === 'application/pdf' || fileName.endsWith('.pdf')) {
        previewEl = document.createElement('embed');
        previewEl.src = url + '#toolbar=0&navpanes=0&scrollbar=0&view=Fit';
        previewEl.type = 'application/pdf';
        previewEl.className = 'preview-thumbnail';
        previewEl.style.pointerEvents = 'none';
        previewEl.style.border = 'none';
        previewEl.loading = 'lazy';
      } else {
        previewEl = document.createElement('img');
        previewEl.src = url;
        previewEl.className = 'preview-thumbnail';
        previewEl.loading = 'lazy';
      }
      
      previewBox.insertBefore(previewEl, previewBox.firstChild);
      previewBox.classList.remove('hidden');
      dropZone.classList.add('hidden');
    }

    document.addEventListener('DOMContentLoaded', () => {
      const fileInput = document.getElementById('image-upload');
      const previewBox = document.getElementById('preview-box');
      const dropZone = document.getElementById('drop-zone');
      const removeBtn = document.getElementById('remove-btn');

      fileInput.addEventListener('change', function() {
        updatePreview(this.files[0], previewBox, dropZone);
      });

      removeBtn?.addEventListener('click', () => {
        if (currentObjectUrl) {
          URL.revokeObjectURL(currentObjectUrl);
          currentObjectUrl = null;
        }
        fileInput.value = '';
        Array.from(previewBox.children).forEach(child => {
          if (child.id !== 'remove-btn') child.remove();
        });
        previewBox.classList.add('hidden');
        dropZone.classList.remove('hidden');
      });

      const form = document.getElementById('bulletin-form');
      const submitBtn = document.getElementById('submit-btn') || form?.querySelector('button[type="submit"], input[type="submit"]');
      if (form && submitBtn) {
        form.addEventListener('submit', () => {
          submitBtn.disabled = true;
          submitBtn.textContent = 'Saving...';
        });
      }
    });
