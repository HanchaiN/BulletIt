extends layout

block content
  if bullet
    .page-panel
      .layout-row-between.mb-lg
        h1 Edit Bulletin
        a.btn.btn-ghost(href=`/bullet/${bullet.id}`)
          span ←
          span Cancel

      .form-wrapper
        .card
          form#bulletin-form.form-vertical(method='POST', action='/' + bullet.id, enctype='multipart/form-data')
            
            //- Logic to determine initial state
            - const hasImage = bullet.image_url ? true : false
            
            //- The Upload Zone (Hidden if image already exists)
            .upload-zone#drop-zone(class=hasImage ? 'hidden' : '')
              label
                span.upload-icon
                  svg(xmlns='http://www.w3.org/2000/svg', viewBox='0 0 24 24', fill='none', stroke='currentColor', stroke-width='1.8', stroke-linecap='round', stroke-linejoin='round', width='24', height='24')
                    path(d='M12 16v-6')
                    path(d='M8 12l4-4 4 4')
                    path(d='M20 16v2a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2v-2')
                    line(x1='12', y1='18', x2='12', y2='22')
                span Click to upload a new photo, video, or PDF
                input#image-upload(type='file', name='image', accept='.jpg, .jpeg, .png, .pdf, .mp4, .mov')
            
            //- The Preview Container (Visible if image exists)
            .preview-container#preview-box(class=hasImage ? '' : 'hidden')
              span.preview-label Current File
              
              if bullet.media_ext === 'pdf'
                embed.preview-thumbnail(src=bullet.image_url + '#toolbar=0&navpanes=0&scrollbar=0&view=Fit', type='application/pdf', loading='lazy', style='pointer-events: none; border: none;')
              else if bullet.media_ext === 'mp4' || bullet.media_ext === 'mov'
                video.preview-thumbnail(src=bullet.image_url, controls, loading='lazy', style="max-width: 100%; max-height: 250px;")
              else if bullet.image_url
                img.preview-thumbnail(src=bullet.image_url, alt=(bullet.title || 'Bulletin media'), loading='lazy')

              button.btn.btn-danger.remove-preview-btn#remove-btn(type="button") ✕ Replace Media

            //- Topic Content
            label.form-label(for='title') Topic
            input.main-input(type='text', name='title', id='title', placeholder='Topic', maxlength='255', required, style='margin-bottom: 1rem;', value=(bullet && bullet.title ? bullet.title : ''))

            label.form-label(for='content') Description
            textarea.main-textarea(name='content', id='content', maxlength='5000', rows='6', required, class='mb-lg')= bullet.content

            .form-actions.full-width
              button.btn.btn-primary#submit-btn(type='submit', style='width: 100%; padding: 0.75rem; font-size: 1rem;') Save Changes

    //- Client-Side Logic for Live Preview
    script.
      let currentObjectUrl = null;

      function updatePreview(file, previewBox, dropZone, includeLabel = true) {
        if (!file) return;
        
        // Revoke the old ObjectURL to prevent memory leaks
        if (currentObjectUrl) {
          URL.revokeObjectURL(currentObjectUrl);
        }
        
        const url = URL.createObjectURL(file);
        currentObjectUrl = url;
        
        // Remove old preview elements (keeping remove button and label)
        const toRemove = [...previewBox.children].filter(child => 
          child.id !== 'remove-btn' && child.className !== 'preview-label'
        );
        toRemove.forEach(el => el.remove());

        const fileType = file.type || '';
        const fileName = (file.name || '').toLowerCase();
        
        let previewEl;
        if (fileType.startsWith('video/') || fileName.endsWith('.mp4') || fileName.endsWith('.mov')) {
          previewEl = document.createElement('video');
          previewEl.src = url;
          previewEl.controls = true;
          previewEl.className = 'preview-thumbnail';
        } else if (fileType === 'application/pdf' || fileName.endsWith('.pdf')) {
          previewEl = document.createElement('embed');
          previewEl.src = url + '#toolbar=0&navpanes=0&scrollbar=0&view=Fit';
          previewEl.type = 'application/pdf';
          previewEl.className = 'preview-thumbnail';
          previewEl.style.pointerEvents = 'none';
          previewEl.style.border = 'none';
        } else {
          previewEl = document.createElement('img');
          previewEl.src = url;
          previewEl.className = 'preview-thumbnail';
        }
        
        if (includeLabel) {
          let labelEl = previewBox.querySelector('.preview-label');
          if (!labelEl) {
            labelEl = document.createElement('span');
            labelEl.className = 'preview-label';
            previewBox.insertBefore(labelEl, previewBox.firstChild);
          }
          labelEl.textContent = 'Proposed Update';
          previewBox.insertBefore(previewEl, labelEl.nextSibling);
        } else {
          previewBox.insertBefore(previewEl, previewBox.firstChild);
        }
        previewBox.classList.remove('hidden');
        dropZone.classList.add('hidden');
      }

      document.addEventListener('DOMContentLoaded', () => {
        const fileInput = document.getElementById('image-upload');
        const previewBox = document.getElementById('preview-box');
        const dropZone = document.getElementById('drop-zone');
        const removeBtn = document.getElementById('remove-btn');

        fileInput.addEventListener('change', function() {
          updatePreview(this.files[0], previewBox, dropZone, true);
        });

        removeBtn?.addEventListener('click', () => {
          if (currentObjectUrl) {
            URL.revokeObjectURL(currentObjectUrl);
            currentObjectUrl = null;
          }
          fileInput.value = '';
          [...previewBox.children].filter(el => el.id !== 'remove-btn').forEach(el => el.remove());
          previewBox.classList.add('hidden');
          dropZone.classList.remove('hidden');
        });

        const form = document.getElementById('bulletin-form');
        const submitBtn = document.getElementById('submit-btn') || form?.querySelector('button[type="submit"], input[type="submit"]');
        if (form && submitBtn) {
          form.addEventListener('submit', () => {
            submitBtn.disabled = true;
            submitBtn.textContent = 'Saving...';
          });
        }
      });
  else
    h1 Bulletin not found
    p The requested bulletin could not be loaded.
